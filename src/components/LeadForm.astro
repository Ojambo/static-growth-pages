---
export interface Props {
  title: string;
  actionUrl: string;
  hiddenFields?: Record<string, string>;
}

const { title, actionUrl, hiddenFields = {} } = Astro.props;
---

<div class="lead-form-wrapper">
  <h2>{title}</h2>
  <form class="lead-form" action={actionUrl} method="POST">
    {Object.entries(hiddenFields).map(([name, value]) => (
      <input type="hidden" name={name} value={value} />
    ))}
    <div class="form-group">
      <label for="firstName">First Name</label>
      <input type="text" id="firstName" name="firstName" required />
    </div>
    <div class="form-group">
      <label for="lastName">Last Name</label>
      <input type="text" id="lastName" name="lastName" required />
    </div>
    <div class="form-group">
      <label for="email">Work Email</label>
      <input type="email" id="email" name="email" required />
    </div>
    <div class="form-group">
      <label for="company">Company</label>
      <input type="text" id="company" name="company" />
    </div>
    <button type="submit" class="submit-btn">Get Started</button>
    <p class="privacy-note">We respect your privacy. Unsubscribe at any time.</p>
  </form>
</div>

<style>
  .lead-form-wrapper {
    background: white;
    border-radius: 8px;
    padding: 2rem;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.1);
    max-width: 500px;
    margin: 0 auto;
  }
  h2 {
    text-align: center;
    color: #1a1a2e;
    margin-bottom: 1.5rem;
  }
  .form-group {
    margin-bottom: 1rem;
  }
  label {
    display: block;
    margin-bottom: 0.375rem;
    font-weight: 500;
    color: #333;
  }
  input {
    width: 100%;
    padding: 0.75rem;
    border: 1px solid #ddd;
    border-radius: 4px;
    font-size: 1rem;
    box-sizing: border-box;
  }
  input:focus {
    outline: none;
    border-color: #4361ee;
    box-shadow: 0 0 0 3px rgba(67, 97, 238, 0.1);
  }
  .submit-btn {
    width: 100%;
    padding: 0.875rem;
    background: #4361ee;
    color: white;
    border: none;
    border-radius: 4px;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.2s;
    margin-top: 0.5rem;
  }
  .submit-btn:hover {
    background: #3a56d4;
  }
  .privacy-note {
    text-align: center;
    font-size: 0.75rem;
    color: #888;
    margin-top: 1rem;
  }
</style>
